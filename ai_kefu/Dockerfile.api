# ============================================================
# Dockerfile.api — AI客服 API 后台服务 (linux/amd64)
# 运行: FastAPI + gunicorn + uvicorn workers
# 端口: 8000
# ============================================================

# ── Stage 1: 安装 Python 依赖 ─────────────────────────────
FROM --platform=linux/amd64 python:3.10-slim AS builder

WORKDIR /build

# 安装编译时系统依赖（chromadb / cryptography 等需要编译）
RUN apt-get update && apt-get install -y --no-install-recommends \
    gcc \
    g++ \
    build-essential \
    libffi-dev \
    libssl-dev \
    && rm -rf /var/lib/apt/lists/*

# 在独立 venv 中安装依赖，避免污染系统 Python
RUN python -m venv /opt/venv
ENV PATH="/opt/venv/bin:$PATH"

COPY requirements.api.txt .
# --prefer-binary: 优先下载预编译 wheel，避免 QEMU 里编译卡死
# --mount=type=cache: BuildKit 缓存 pip 下载，重复构建秒过
# 不指定 mirror: GitHub Actions 在美国，aliyun 反而更慢
RUN --mount=type=cache,target=/root/.cache/pip \
    pip install --upgrade pip && \
    pip install \
        --prefer-binary \
        --timeout 120 \
        -r requirements.api.txt

# ── Stage 2: 最终运行镜像 ─────────────────────────────────
FROM --platform=linux/amd64 python:3.10-slim

ENV TZ=Asia/Shanghai \
    PYTHONIOENCODING=utf-8 \
    LANG=C.UTF-8 \
    PATH="/opt/venv/bin:$PATH" \
    PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1

# 运行时系统依赖（慢，放在最前缓存）：
#   tzdata  — 时区数据
#   nodejs  — PyExecJS 运行时（闲鱼签名算法必需，需 Node.js >= 18）
RUN apt-get update && apt-get install -y --no-install-recommends \
    tzdata \
    nodejs \
    && ln -snf /usr/share/zoneinfo/Asia/Shanghai /etc/localtime \
    && echo Asia/Shanghai > /etc/timezone \
    && rm -rf /var/lib/apt/lists/*

# LABEL 放在慢速 RUN 之后，避免版本号变动破坏上面的缓存层
LABEL maintainer="coderxiu<coderxiu@qq.com>"
LABEL description="闲鱼AI客服 - API后台服务"
LABEL version="2.0"

# 从 builder 阶段复制虚拟环境（requirements.txt 不变时命中缓存）
COPY --from=builder /opt/venv /opt/venv

# 工作目录为 ai_kefu 包的父目录，使 `import ai_kefu` 正确解析
WORKDIR /workspace

# 创建运行时目录（放在 COPY 代码之前，避免每次代码变动重跑）
RUN mkdir -p \
    /workspace/ai_kefu/data \
    /workspace/ai_kefu/logs \
    /workspace/ai_kefu/chroma_data \
    /workspace/ai_kefu/storage

# 将当前上下文（ai_kefu 包内容）复制为 ai_kefu 包（每次都变，放最后）
COPY . /workspace/ai_kefu/

# 暴露端口
EXPOSE 8000

# 以 gunicorn + UvicornWorker 启动，4 个 worker 适合生产环境
# 通过环境变量 GUNICORN_WORKERS 可覆盖 worker 数量
CMD ["sh", "-c", \
     "gunicorn ai_kefu.api.main:app \
      -w ${GUNICORN_WORKERS:-4} \
      -k uvicorn.workers.UvicornWorker \
      --bind 0.0.0.0:8000 \
      --timeout 120 \
      --access-logfile -"]
